# Example environment variables for new_tui_project_template
# Copy this to .env and customize as needed

# Debug mode - can be overridden by config.yaml or --debug flag
# DEBUG=false

# Logging configuration
# LOG_LEVEL=INFO

# Application settings
# APP_TITLE="TUI Template"
# APP_THEME="dark"

# Development settings
# DEV_MODE=false
# AUTO_RELOAD=false

# Custom application environment variables
# Add your application-specific environment variables here
# DATABASE_URL=sqlite:///app.db
# API_KEY=your-api-key-here
# SECRET_KEY=your-secret-key-here